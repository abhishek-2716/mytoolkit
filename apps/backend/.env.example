# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="mysql://root:YOUR_PASSWORD@localhost:3306/mytoolshub"

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_PREFIX=api

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production
JWT_REFRESH_EXPIRES_IN=30d

# ─── CORS ────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Admin seed (first run only) ─────────────────────────────────────────────
ADMIN_EMAIL=admin@mytoolshub.com
ADMIN_PASSWORD=Admin@1212
ADMIN_NAME=Admin
