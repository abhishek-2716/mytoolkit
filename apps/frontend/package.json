    "@rollup/rollup-linux-x64-gnu": "4.62.2",
    "@rollup/rollup-linux-x64-musl": "4.62.2",
    "@rollup/rollup-linux-arm64-gnu": "4.62.2",
    "@rollup/rollup-linux-arm64-musl": "4.62.2"
  }
