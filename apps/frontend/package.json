    "react-dom": "^19.1.0",
    "react-hook-form": "^7.56.4",
    "react-hot-toast": "^2.5.2",
    "react-router-dom": "^7.6.2",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.25.51",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@tailwindcss/vite": "^4.1.8",
    "@tanstack/react-query-devtools": "^5.80.6",
    "@types/react": "^19.1.5",
