# ────────────────────────────────────────────────────────────
# Application
# ────────────────────────────────────────────────────────────

VITE_APP_NAME=ToolNest
VITE_APP_URL=http://localhost:3000
VITE_APP_ENV=development

# ────────────────────────────────────────────────────────────
# API
# ────────────────────────────────────────────────────────────

VITE_API_BASE_URL=http://localhost:4000/api

# ────────────────────────────────────────────────────────────
# Backend (server-side only — never expose to frontend)
# ────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://user:password@localhost:5432/toolnest_dev

JWT_SECRET=replace-with-a-secure-random-string-minimum-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ────────────────────────────────────────────────────────────
# File Storage
# ────────────────────────────────────────────────────────────

# Development: local  |  Production: s3
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads

# AWS S3 / Cloudflare R2 (production)
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_ENDPOINT=

# ────────────────────────────────────────────────────────────
# Email (Nodemailer)
# ────────────────────────────────────────────────────────────

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@toolnest.io

# ────────────────────────────────────────────────────────────
# Redis (Phase 2+)
# ────────────────────────────────────────────────────────────

REDIS_URL=redis://localhost:6379

# ────────────────────────────────────────────────────────────
# Analytics (optional)
# ────────────────────────────────────────────────────────────

VITE_ANALYTICS_ID=

# ────────────────────────────────────────────────────────────
# AI (Phase 5+)
# ────────────────────────────────────────────────────────────

OPENAI_API_KEY=
