# Normalize line endings across all operating systems
* text=auto eol=lf

# Explicitly mark text files
*.ts      text eol=lf
*.tsx     text eol=lf
*.js      text eol=lf
*.jsx     text eol=lf
*.json    text eol=lf
*.md      text eol=lf
*.yaml    text eol=lf
*.yml     text eol=lf
*.css     text eol=lf
*.html    text eol=lf
*.sh      text eol=lf

# Mark binary files — do not diff or merge
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.webp    binary
*.ico     binary
*.svg     text eol=lf
*.woff    binary
*.woff2   binary
*.ttf     binary
*.eot     binary
*.pdf     binary
*.zip     binary
*.gz      binary
*.tar     binary
