{
  "name": "toolnest",
  "private": true,
  "version": "0.1.0",
  "description": "ToolNest — Modern Online Productivity Platform",
  "scripts": {
    "dev": "pnpm --filter @toolnest/frontend dev",
    "build": "pnpm --filter @toolnest/frontend build",
    "preview": "pnpm --filter @toolnest/frontend preview",
    "lint": "pnpm -r --parallel lint",
    "lint:fix": "pnpm -r --parallel lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml,css}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml,css}\" --ignore-path .gitignore",
    "typecheck": "pnpm -r --parallel typecheck",
    "validate": "pnpm run format:check && pnpm run typecheck && pnpm run lint",
    "clean": "pnpm -r --parallel exec rm -rf dist node_modules/.cache",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.5.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@11.9.0"
}
